# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# DSA source materials (reference only — assets are copied into public/ and src/lib)
/DSA/

# DSA Builder personal signatures — staged locally, served from Supabase
# Storage with auth at render time (see PR B). Anything matching here
# stays out of the public Vercel build.
/public/dsa-builder/images/*
!/public/dsa-builder/images/mcr-logo.png
